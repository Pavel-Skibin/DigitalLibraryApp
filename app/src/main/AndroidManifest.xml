<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ИСПРАВЛЕНО: убран пробел в разрешении INTERNET -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- ДОПОЛНИТЕЛЬНО: добавлено разрешение для Wi-Fi состояния -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />

    <application
        android:name=".MyApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:usesCleartextTraffic="true"
        android:theme="@style/Theme.Material3.Light.NoActionBar"
        tools:targetApi="31">

        <!-- Main Activity (Библиотека) -->
        <activity
            android:name=".catalog.ui.MainActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <!-- ИСПРАВЛЕНО: убраны пробелы в action и category -->
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Book Detail Activity -->
        <activity
            android:name=".catalog.ui.BookDetailActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Reader Activity -->
        <activity
            android:name=".reader.ui.ReaderActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize" />

    </application>

</manifest>